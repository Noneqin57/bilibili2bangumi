{
  "manifest_version": 3,
  "name": "bilibili2bangumi",
  "version": "0.5.0",
  "description": "在 B 站观看 UGC 番剧视频时，手动搜索并同步到 Bangumi 收藏进度",
  "author": "bilibili2bangumi",
  "homepage_url": "https://github.com/bilibili2bangumi/bilibili2bangumi",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://www.bilibili.com/video/*",
    "*://api.bgm.tv/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://www.bilibili.com/video/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["*://www.bilibili.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
